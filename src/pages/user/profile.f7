<style>
  /* Stats grid gap */
  .grid-gap {
    --f7-grid-gap: 10px;
  }

  /* Stat Card Profile */
  .profile-stat-card {
    border: none !important;
    background: #ffffff !important;
  }

  /* Circle icon wrapper on list */
