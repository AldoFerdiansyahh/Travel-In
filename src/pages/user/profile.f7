<script>
  export default (props, { $store, $f7, $router, $update }) => {
    // Data Profile Default
    let userProfile = {
      name: 'Irfan Ramadhani',
      email: 'irfan.ramadhani@student.lpkia.ac.id',
    };

    const editProfile = () => {
      $f7.dialog.prompt('Ubah nama Anda:', 'Travel-In', (value) => {
        if (value.trim()) {
          userProfile.name = value;
          $update();
          $f7.toast.create({ text: 'Nama berhasil diubah!', closeTimeout: 2000 }).open();
        }
      });
    };

    const handleLogout = () => {
      $f7.dialog.confirm('Apakah Anda yakin ingin keluar dari aplikasi?', 'Konfirmasi', () => {
        $f7.toast.create({ text: 'Berhasil keluar akun.', closeTimeout: 1500 }).open();
        // Arahkan kembali ke halaman login/landing utama
        $router.navigate('/');
      });
    };

    return $render;
  };
</script>