<template>
  <div class="page no-toolbar" data-name="register">
    <div class="page-content" style="background-color: #ffffff;">
      <!-- Pembungkus Utama dengan Padding -->
      <div style="padding: 20px 30px 40px 30px;">
        
        <!-- Tombol Back -->
        <div style="margin-top: 10px; margin-bottom: 30px;">
          <a href="/" class="link back" style="display: flex; align-items: center; justify-content: center; width: 45px; height: 45px; background-color: #f3f4f6; border-radius: 12px; color: #000000;">
            <i class="f7-icons" style="font-size: 20px;">arrow_left</i>
          </a>
        </div>

        <!-- Header Title -->
        <div style="margin-bottom: 30px;">
          <h1 style="font-size: 32px; font-weight: 800; color: #111827; margin: 0; letter-spacing: -0.5px;">Daftar Akun</h1>
          <p style="color: #9ca3af; font-size: 15px; font-weight: 500; margin-top: 8px;">Lengkapi data untuk memesan tiket</p>
        </div>

        <!-- Form Input Container -->
        <div style="display: flex; flex-direction: column; gap: 18px;">
          
          <!-- Field Nama -->
          <div>
            <label style="display: block; text-transform: uppercase; font-size: 11px; font-weight: 800; color: #111827; margin-bottom: 8px; margin-left: 5px;">Nama Lengkap</label>
            <input type="text" placeholder="Nama Anda"
              style="width: 100%; border: 1px solid #f3f4f6; background-color: #f9fafb; border-radius: 16px; padding: 16px; font-size: 15px; font-weight: 600; box-sizing: border-box; outline: none;"
              .value="${form.nama}" @input="${(e) => { form.nama = e.target.value; $update(); }}" />
          </div>

          <!-- Field Email -->
          <div>
            <label style="display: block; text-transform: uppercase; font-size: 11px; font-weight: 800; color: #111827; margin-bottom: 8px; margin-left: 5px;">Email</label>
            <input type="email" placeholder="nama@email.com"
              style="width: 100%; border: 1px solid #f3f4f6; background-color: #f9fafb; border-radius: 16px; padding: 16px; font-size: 15px; font-weight: 600; box-sizing: border-box; outline: none;"
              .value="${form.email}" @input="${(e) => { form.email = e.target.value.trim(); $update(); }}" />
          </div>

          <!-- Field WhatsApp -->
          <div>
            <label style="display: block; text-transform: uppercase; font-size: 11px; font-weight: 800; color: #111827; margin-bottom: 8px; margin-left: 5px;">WhatsApp</label>
            <input type="tel" placeholder="08975614300"
              style="width: 100%; border: 1px solid #f3f4f6; background-color: #f9fafb; border-radius: 16px; padding: 16px; font-size: 15px; font-weight: 600; box-sizing: border-box; outline: none;"
              .value="${form.whatsapp}" @input="${(e) => { form.whatsapp = e.target.value.trim(); $update(); }}" />
          </div>

          <!-- Field Password -->
          <div>
            <label style="display: block; text-transform: uppercase; font-size: 11px; font-weight: 800; color: #111827; margin-bottom: 8px; margin-left: 5px;">Password</label>
            <input type="password" placeholder="••••••••"
              style="width: 100%; border: 1px solid #f3f4f6; background-color: #f9fafb; border-radius: 16px; padding: 16px; font-size: 15px; font-weight: 600; box-sizing: border-box; outline: none;"
              .value="${form.password}" @input="${(e) => { form.password = e.target.value; $update(); }}" />
          </div>

          <!-- Field Konfirmasi Password -->
          <div>
            <label style="display: block; text-transform: uppercase; font-size: 11px; font-weight: 800; color: #111827; margin-bottom: 8px; margin-left: 5px;">Konfirmasi Password</label>
            <input type="password" placeholder="••••••••"
              style="width: 100%; border: 1px solid #f3f4f6; background-color: #f9fafb; border-radius: 16px; padding: 16px; font-size: 15px; font-weight: 600; box-sizing: border-box; outline: none;"
              .value="${form.password_confirm}" @input="${(e) => { form.password_confirm = e.target.value; $update(); }}" />
          </div>

          <!-- Button Register -->
          <button @click="${handleRegister}" 
            style="width: 100%; background-color: #000000; color: #ffffff; border: none; border-radius: 18px; padding: 20px; font-size: 15px; font-weight: 900; letter-spacing: 0.1em; cursor: pointer; margin-top: 10px; box-shadow: 0 10px 20px -5px rgba(0, 0, 0, 0.2);">
            DAFTAR SEKARANG
          </button>

        </div>

        <!-- Login Link -->
        <div style="margin-top: 40px; text-align: center;">
          <p style="color: #9ca3af; font-size: 14px; font-weight: 500;">
            Sudah punya akun? <a href="/" class="link" style="color: #F7C910; font-weight: 700; margin-left: 5px;">Masuk</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
  import { registerWithFirebase } from '../../js/auth.js';

  export default (props, { $f7, $router, $update }) => {
    const router = $router || ($f7.views && $f7.views.current && $f7.views.current.router) || ($f7.views && $f7.views.main && $f7.views.main.router);
    let form = {
      nama: '',
      email: '',
      whatsapp: '',
      password: '',
      password_confirm: '',
    };

    const handleRegister = async () => {
      if (!form.nama || !form.email || !form.whatsapp || !form.password || !form.password_confirm) {
        $f7.dialog.alert('Mohon lengkapi semua data.', 'Travel-In');
        return;
      }

      if (form.password !== form.password_confirm) {
        $f7.dialog.alert('Password dan konfirmasi password harus sama.', 'Travel-In');
        return;
      }

      if (!router || !router.navigate) {
        $f7.dialog.alert('Router tidak tersedia. Silakan muat ulang aplikasi.', 'Travel-In');
        return;
      }

      $f7.preloader.show();
      try {
        await registerWithFirebase({
          name: form.nama,
          email: form.email,
          password: form.password,
          whatsapp: form.whatsapp,
        });
        $f7.preloader.hide();
        $f7.dialog.alert('Akun berhasil dibuat. Silakan masuk.', 'Sukses', () => {
          router.navigate('/login/');
        });
      } catch (error) {
        $f7.preloader.hide();
        console.error('Registrasi Error:', error);
        const message = error.message || 'Registrasi gagal. Silakan coba lagi.';
        $f7.dialog.alert(message, 'Gagal Registrasi');
      }
    };

    return $render;
  };
</script>