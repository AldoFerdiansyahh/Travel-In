    border-radius: 999px;
    padding: 6px 10px;
    font-size: 9px;
    font-weight: 900;
  }

  .time-route-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 10px;
    align-items: center;
    margin: 20px 0 16px 0;
  }

  .time-route-row strong {
    display: block;
    font-size: 25px;
    line-height: 1;
