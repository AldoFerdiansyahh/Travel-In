<template>
  <div class="page no-navbar schedule-page" data-name="search-results">

    <div class="schedule-header">
      <div class="schedule-top">
        <a href="/home/" class="back-plain">
          <i class="f7-icons">chevron_left</i>
        </a>

        <div>
          <h1>${query.origin || 'JADWAL'}</h1>
          <p>${formatDate(query.date)}</p>
        </div>
      </div>

      <div class="filter-row">
        <button class="filter-chip active">Terpagi</button>
        <button class="filter-chip">Harga Termurah</button>
        <button class="filter-chip">Hiace Luxury</button>
      </div>
    </div>

    <div class="page-content schedule-content">

      ${filteredSchedules.length > 0 ? filteredSchedules.map((schedule) => $h`
        <div class="schedule-wire-card" @click="${() => goToBooking(schedule.id)}">

          <div class="card-head">
            <h2>${schedule.vehicle || 'HIACE LUXURY'}</h2>
            <span>${schedule.type || 'REGULER'}</span>
          </div>

          <div class="time-route-row">
            <div>
              <strong>${schedule.time || '08:00'}</strong>
              <small>${schedule.origin || 'BDO'}</small>
            </div>

            <div class="dash-line"></div>

            <div class="text-align-right">
              <strong>${schedule.arrivalTime || getArrivalTime(schedule.time)}</strong>
              <small>${schedule.destination || 'JKT'}</small>
            </div>
          </div>

          <div class="bottom-card-row">
            <div class="price-text">Rp ${formatRupiah(schedule.price)}</div>

            <button class="choose-btn" @click="${(e) => goToBooking(schedule.id, e)}">
              PILIH
            </button>
          </div>

        </div>
      `) : $h`
        <div class="empty-state">
          <i class="f7-icons">calendar_badge_exclamationmark</i>
          <h3>Jadwal Tidak Tersedia</h3>
          <p>Coba cari rute atau tanggal lain.</p>
        </div>
      `}

    </div>

    <div class="ios-user-tabbar">
      <a href="/home/" class="ios-tab-item">
        <i class="f7-icons">house_fill</i>
        <span>Beranda</span>
      </a>

      <a href="/search-results/" class="ios-tab-item active">
        <i class="f7-icons">calendar</i>
        <span>Jadwal</span>
      </a>

      <a @click="${goToETicket}" class="ios-tab-item">
        <i class="f7-icons">ticket_fill</i>
        <span>Tiket</span>
      </a>
    </div>

  </div>
</template>

<style>
  @import url('https://fonts.cdnfonts.com/css/sf-pro-display');

  * {
    font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, sans-serif;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  .schedule-page {
    background: #F5F6FA !important;
  }

  .schedule-header {
    background: linear-gradient(135deg, #ffffff 0%, #fff7d6 100%);
    padding: 54px 18px 16px 18px;
    border-bottom-left-radius: 28px;
    border-bottom-right-radius: 28px;
    box-shadow: 0 16px 35px rgba(0,0,0,0.06);
  }

  .schedule-top {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 18px;
  }

  .back-plain {
    color: #111 !important;
    margin-top: 1px;
  }

  .back-plain i {
    font-size: 21px;
    font-weight: 900;
  }

  .schedule-top h1 {
    margin: 0;
    font-size: 18px;
    font-weight: 900;
    color: #111;
    letter-spacing: -0.04em;
  }

  .schedule-top p {
    margin: 4px 0 0 0;
    font-size: 11px;
    color: #8E8E93;
    font-weight: 700;
  }

  .filter-row {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    padding-bottom: 2px;
  }

  .filter-chip {
    border: none;
    background: #ffffff;
    color: #111;
    border-radius: 999px;
    padding: 8px 13px;
    font-size: 10px;
    font-weight: 900;
    white-space: nowrap;
    box-shadow: 0 8px 18px rgba(0,0,0,0.06);
  }

  .filter-chip.active {
    background: #111;
    color: #FFD43B;
  }

  .schedule-content {
    background: #F5F6FA !important;
    padding: 18px 16px 110px 16px !important;
  }

  .schedule-wire-card {
    background: #FFFFFF;
    border: none;
    border-radius: 24px;
    padding: 17px;
    margin-bottom: 15px;
    box-shadow: 0 14px 32px rgba(0,0,0,0.07);
    position: relative;
    overflow: hidden;
    cursor: pointer;
  }

  .schedule-wire-card::before {
    content: "";
    position: absolute;
    left: 0;
    top: 24px;
    width: 5px;
    height: 42px;
    background: #FFD43B;
    border-radius: 0 10px 10px 0;
  }

  .card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .card-head h2 {
    margin: 0;
    font-size: 17px;
    color: #111;
    font-weight: 900;
    letter-spacing: -0.04em;
  }

  .card-head span {
    background: #FFF4C2;
