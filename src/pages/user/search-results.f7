    font-weight: 900;
  }

  .dash-line {
    border-top: 2px dashed #D6D8DF;
    margin-top: -10px;
  }

  .bottom-card-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #F7F8FA;
    border-radius: 17px;
    padding: 12px;
  }

  .price-text {
    font-size: 19px;
    font-weight: 900;
    color: #111;
    letter-spacing: -0.04em;
  }

  .choose-btn {
    background: #FFD43B;
    color: #111;
    border: none;
    border-radius: 13px;
    padding: 11px 18px;
    font-size: 11px;
    font-weight: 900;
    box-shadow: 0 8px 18px rgba(255, 212, 59, 0.35);
    cursor: pointer;
  }

  .empty-state {
    text-align: center;
    padding: 80px 20px;
    color: #8E8E93;
  }

  .empty-state i {
    font-size: 42px;
    opacity: 0.4;
  }

  .empty-state h3 {
    color: #111;
    margin: 12px 0 4px 0;
  }

  .empty-state p {
    margin: 0;
  }

  .ios-user-tabbar {
    position: fixed;
    left: 18px;
    right: 18px;
    bottom: 18px;
    height: 68px;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 24px;
    display: flex;
    justify-content: space-around;
    align-items: center;
    z-index: 99999;
    box-shadow: 0 18px 35px rgba(0,0,0,0.12);
  }

  .ios-tab-item {
    flex: 1;
    height: 100%;
    color: #9A9AA2 !important;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    text-decoration: none !important;
    font-weight: 800;
  }

  .ios-tab-item i {
    font-size: 22px;
  }

  .ios-tab-item span {
    font-size: 10px;
  }

  .ios-tab-item.active,
  .ios-tab-item.active i {
    color: #FFB300 !important;
  }
</style>

<script>
  export default (props, { $store, $router, $f7, $update, $on }) => {
    const query = (props.route && props.route.query) || {};
    let schedules = $store.getters.schedules.value || [];

    $on('pageBeforeIn', () => {
      $store.dispatch('fetchSchedules').then(() => {
        schedules = $store.getters.schedules.value || [];
        $update();
      });
    });

    const filteredSchedules = schedules.filter((schedule) => {
      const originMatch = !query.origin || String(schedule.origin || '').toLowerCase().includes(String(query.origin).toLowerCase());
      const destMatch = !query.destination || String(schedule.destination || '').toLowerCase().includes(String(query.destination).toLowerCase());
      const dateMatch = !query.date || schedule.date === query.date;

      return originMatch && destMatch && dateMatch;
    });

    const formatRupiah = (value) => {
      return Number(value || 0).toLocaleString('id-ID');
    };

    const formatDate = (date) => {
      if (!date) return 'Pilih jadwal perjalanan';

      const bulan = [
        'Januari', 'Februari', 'Maret', 'April', 'Mei', 'Juni',
        'Juli', 'Agustus', 'September', 'Oktober', 'November', 'Desember'
      ];

      const dateObject = new Date(date);
      if (isNaN(dateObject.getTime())) return date;

      return `${dateObject.getDate()} ${bulan[dateObject.getMonth()]} ${dateObject.getFullYear()}`;
    };

    const getArrivalTime = (time) => {
      if (!time) return '11:00';

      const [hour, minute] = time.split(':').map(Number);
      const arrivalHour = (hour + 3).toString().padStart(2, '0');

      return `${arrivalHour}:${String(minute || 0).padStart(2, '0')}`;
    };

    const goToBooking = (id, e) => {
      if (e && e.preventDefault) e.preventDefault();
      if (e && e.stopPropagation) e.stopPropagation();

      if (!id) {
        $f7.dialog.alert('ID jadwal tidak ditemukan.');
        return;
      }

      $router.navigate(`/booking/${id}/`);
    };

    const goToETicket = () => {
      const tickets = $store.getters.tickets.value || [];

      if (tickets.length > 0) {
        $router.navigate(`/e-ticket/${tickets[0].id}/`);
      } else {
        $f7.dialog.alert('Belum ada tiket yang tersedia.');
      }
    };

    return $render;
  };
</script>