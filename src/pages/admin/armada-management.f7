</style>

<script>
  import $ from 'dom7'; // Mengimpor Dom7 untuk manipulasi scroll halaman

  export default (props, { $store, $f7, $router, $update }) => {
    let showForm = false;
    let isEditing = false;
    let editingId = null;
    const armadas = $store.getters.armadas.value || [];

    let unitForm = {
      name: '',
      plate: '',
      capacity: '',
      year: '',
      facilities: '',
      status: 'Available',
    };

    const updateField = (field) => (e) => {
      unitForm[field] = e.target.value;
      $update();
    };

    // Scroll Otomatis (Smooth Scroll) ke area form penambahan unit
    const openUnitForm = () => {
      showForm = true;
      isEditing = false;
      editingId = null;
      unitForm = { name: '', plate: '', capacity: '', year: '', facilities: '', status: 'Available' };
      $update();

      // Bergeser ke bawah (lokasi form baru dibuat di DOM)
      setTimeout(() => {
        $('.page-content').animate(
          {
            scrollTop: $('.armada-form-block').offset().top + $('.page-content').scrollTop() - 100
          },
          600 // durasi scroll 0.6 detik
        );
      }, 100);
    };

    const closeForm = () => {
      showForm = false;
      isEditing = false;
      editingId = null;
      $update();
      
      // Scroll kembali ke atas daftar unit saat form ditutup
      setTimeout(() => {
        $('.page-content').animate({ scrollTop: 0 }, 400);
      }, 100);
    };

    const saveUnit = () => {
      if (!unitForm.name || !unitForm.plate || !unitForm.capacity) {
        $f7.dialog.alert('Lengkapi nama, plat, dan kapasitas armada.', 'Travel-In');
        return;
      }
      const armadaData = {
        id: isEditing ? editingId : `ARM-${Date.now().toString().slice(-4)}`,
        name: unitForm.name,
        plate: unitForm.plate,
        capacity: Number(unitForm.capacity),
        year: unitForm.year,
        facilities: unitForm.facilities,
        status: unitForm.status,
      };
      if (isEditing) {
        $store.dispatch('updateArmada', armadaData);
        $f7.toast.create({ text: 'Armada berhasil diperbarui.', closeTimeout: 2000 }).open();
      } else {
        $store.dispatch('addArmada', armadaData);
        $f7.toast.create({ text: 'Armada berhasil ditambahkan.', closeTimeout: 2000 }).open();
      }
      closeForm();
    };

    // Scroll Otomatis saat mode Edit Unit diaktifkan
    const editUnit = (id) => {
      const armada = armadas.find((item) => item.id === id);
      if (!armada) return;
      showForm = true;
      isEditing = true;
      editingId = id;
      unitForm = {
        name: armada.name,
        plate: armada.plate,
        capacity: armada.capacity,
        year: armada.year || '',
        facilities: armada.facilities || '',
        status: armada.status,
      };
      $update();

      setTimeout(() => {
        $('.page-content').animate(
          {
            scrollTop: $('.armada-form-block').offset().top + $('.page-content').scrollTop() - 100
          },
          600
        );
      }, 100);
    };

    const viewSchedule = (id) => {
      $router.navigate('/admin/schedules/');
    };

    const toggleArmadaStatus = (id) => {
      const armada = armadas.find((item) => item.id === id);
      if (!armada) return;
      const newStatus = armada.status === 'Available' ? 'In Service' : 'Available';
      $store.dispatch('updateArmada', { ...armada, status: newStatus });
      $f7.toast.create({ text: `Status ${armada.name} sekarang ${newStatus}.`, closeTimeout: 2000 }).open();
      $update();
    };

    return $render;
  };
</script>