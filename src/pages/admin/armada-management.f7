  }

  @media (max-width: 740px) {
    .stat-grid {
      grid-template-columns: 1fr;
    }
    .armada-card-body {
      grid-template-columns: 1fr;
    }
    .form-grid {
      grid-template-columns: 1fr;
    }
    .form-row.form-full {
      grid-column: span 1;
    }
