    color: #111827;
  }

  .form-card {
    background: #ffffff;
    border-radius: 22px;
    padding: 22px;
    box-shadow: 0 15px 40px rgba(15, 23, 42, 0.06);
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }

  .form-row {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-row-half {
    width: 100%;
  }

  .form-row.form-row-half {
    display: block;
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
