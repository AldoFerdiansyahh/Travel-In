<template>
  <div class="page" data-name="admin-armadas">
    <div class="navbar navbar-transparent">
      <div class="navbar-bg custom-admin-navbar"></div>
      <div class="navbar-inner sliding">
        <div class="left">
          <a href="#" class="link back text-color-black nav-back">
            <i class="icon f7-icons font-bold text-xl">arrow_left</i>
          </a>
        </div>
        <div class="title page-title">Manajemen Armada</div>
        <div class="right">
          <button @click="${openUnitForm}" class="button add-unit-button">
            + UNIT
          </button>
        </div>
      </div>
    </div>

    <div class="page-content admin-armada-content">
      <div class="section-header">
        <div>
          <h2 class="section-title">Kelola Armada</h2>
          <p class="section-subtitle">Kelola dan pantau seluruh operasional unit armada Travel-In.</p>
        </div>
      </div>

      <div class="stat-grid">
        <div class="stat-card">
          <span class="stat-label">Total</span>
          <span class="stat-number">${armadas.length || 0}</span>
        </div>
        <div class="stat-card stat-card-success">
          <span class="stat-label">Tersedia</span>
          <span class="stat-number">${armadas.filter((item) => item.status === 'Available').length || 0}</span>
        </div>
        <div class="stat-card stat-card-warning">
          <span class="stat-label">Servis</span>
          <span class="stat-number">${armadas.filter((item) => item.status !== 'Available').length || 0}</span>
        </div>
      </div>

      <div class="section-subheader">Daftar Unit Aktif</div>

      <div class="armada-list">
        <ul>
          ${armadas.length > 0 ? armadas.map((armada) => $h`
            <li class="armada-item">
              <div class="armada-card">
                <div class="armada-card-header">
                  <div class="armada-meta">
                    <div class="armada-icon ${armada.status === 'Available' ? 'bg-blue-tint' : 'bg-orange-tint'}">
                      <i class="icon f7-icons ${armada.status === 'Available' ? 'color-blue' : 'color-orange'}">bus_fill</i>
                    </div>
                    <div>
                      <h3 class="armada-name">${armada.name}</h3>
                      <p class="armada-subtitle">Plat: ${armada.plate}</p>
                    </div>
                  </div>
                  <span class="status-pill ${armada.status === 'Available' ? 'color-green' : 'color-orange'}">${armada.status}</span>
                </div>

                <div class="armada-card-body">
                  <div class="armada-info">
                    <span class="info-label">Kapasitas</span>
                    <span class="info-value">${armada.capacity} Kursi</span>
                  </div>
                  <div class="armada-info">
                    <span class="info-label">Tahun Unit</span>
                    <span class="info-value">${armada.year || '-'}</span>
                  </div>
                  <div class="armada-info flex-grow">
                    <span class="info-label">Fasilitas</span>
                    <span class="info-value info-ellipsis">${armada.facilities || 'Standar'}</span>
                  </div>
                </div>

                <div class="armada-card-actions">
                  <button class="button button-small button-outline action-button" @click="${() => editUnit(armada.id)}">Edit</button>
                  <button class="button button-small button-fill action-button button-blue" @click="${() => viewSchedule(armada.id)}">Jadwal</button>
                  <button class="button button-small button-fill action-button ${armada.status === 'Available' ? 'button-red' : 'button-green'}" @click="${() => toggleArmadaStatus(armada.id)}">
                    ${armada.status === 'Available' ? 'Nonaktifkan' : 'Aktifkan'}
                  </button>
                </div>
              </div>
            </li>
          `) : $h`
            <li class="armada-empty">
              <div class="empty-card">
                <i class="icon f7-icons text-5xl color-gray">bus_fill</i>
                <h3 class="empty-title">Armada Belum Terdaftar</h3>
                <p class="empty-text">Belum ada unit armada yang terdaftar. Tekan tombol Tambah Unit di atas untuk memulai.</p>
              </div>
            </li>
          `}
        </ul>
      </div>

      ${showForm ? $h`
        <div class="armada-form-section">
          <h3 class="form-title">${isEditing ? 'Ubah Informasi Armada' : 'Registrasi Armada Baru'}</h3>
          <div class="form-card">
            <div class="form-grid">
              <div class="form-row">
                <label class="form-label">Nama Armada</label>
                <input type="text" class="form-input" placeholder="Contoh: Hiace Premio Luxury" .value="${unitForm.name}" @input="${updateField('name')}" required />
              </div>
              <div class="form-row">
                <label class="form-label">Plat Nomor</label>
                <input type="text" class="form-input" placeholder="Contoh: D 1990 ADO" .value="${unitForm.plate}" @input="${updateField('plate')}" required />
              </div>
              <div class="form-row form-row-half">
                <label class="form-label">Kapasitas Kursi</label>
                <input type="number" class="form-input" placeholder="12" .value="${unitForm.capacity}" @input="${updateField('capacity')}" required />
              </div>
              <div class="form-row form-row-half">
                <label class="form-label">Tahun Unit</label>
                <input type="number" class="form-input" placeholder="2024" .value="${unitForm.year}" @input="${updateField('year')}" />
              </div>
              <div class="form-row form-full">
                <label class="form-label">Fasilitas Utama</label>
                <input type="text" class="form-input" placeholder="Full AC, TV, WiFi, Charger USB" .value="${unitForm.facilities}" @input="${updateField('facilities')}" />
              </div>
            </div>
            <div class="form-actions">
              <button class="button button-fill button-large button-round button-save" @click="${saveUnit}">${isEditing ? 'SIMPAN' : 'TAMBAH ARMADA'}</button>
              <button class="button button-outline button-large button-round button-cancel" @click="${closeForm}">BATAL</button>
            </div>
          </div>
        </div>
      ` : ''}
    </div>
  </div>
</template>

