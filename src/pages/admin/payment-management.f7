<script>
  export default (props, { $f7, $router, $update }) => {
    let payments = [
      {
        id: 'PAY-001',
        ticketId: 'TCK-001',
        passenger: 'Aldo Ferdiansyah',
        route: 'Bandung - Jakarta',
        method: 'Transfer',
        amount: 150000,
        date: '28/05/2026',
        status: 'Pending',
      },
      {
        id: 'PAY-002',
        ticketId: 'TCK-002',
        passenger: 'Andi Aryanto',
        route: 'Bandung - Bogor',
        method: 'QRIS',
        amount: 125000,
        date: '28/05/2026',
        status: 'Paid',
      },
    ];

    let pendingCount = payments.filter((item) => item.status === 'Pending').length;
    let paidCount = payments.filter((item) => item.status === 'Paid').length;

    const formatRupiah = (value) => {
      return value.toLocaleString('id-ID');
    };

    const refreshCount = () => {
      pendingCount = payments.filter((item) => item.status === 'Pending').length;
      paidCount = payments.filter((item) => item.status === 'Paid').length;
    };

    const goBack = (e) => {
      if (e && e.preventDefault) e.preventDefault();
      $router.navigate('/admin/');
    };

    const verifyPayment = (id) => {
      payments = payments.map((item) => {
        if (item.id === id) {
          return { ...item, status: 'Paid' };
        }
        return item;
      });

      refreshCount();

      $f7.toast.create({
        text: 'Pembayaran berhasil diverifikasi',
        closeTimeout: 2000,
      }).open();

      $update();
    };

    const rejectPayment = (id) => {
      $f7.dialog.confirm('Yakin ingin menolak pembayaran ini?', 'Konfirmasi', () => {
        payments = payments.filter((item) => item.id !== id);
        refreshCount();

        $f7.toast.create({
          text: 'Pembayaran ditolak',
          closeTimeout: 2000,
        }).open();

        $update();
      });
    };

    const viewTicket = (ticketId) => {
      $router.navigate('/admin/tickets/');
    };

    return $render;
  };
</script>