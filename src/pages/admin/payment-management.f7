<template>
  <div class="page no-toolbar pay-page" data-name="admin-payments">

    <div class="pay-hero">
      <div class="pay-nav">
        <a href="/admin/" @click="${goBack}" class="pay-back">
          <i class="f7-icons">chevron_left</i>
        </a>

        <div class="pay-status">
          <span></span>
          PAYMENT
        </div>
      </div>

      <div class="pay-title-wrap">
        <div class="pay-icon">
          <i class="f7-icons">creditcard_fill</i>
        </div>
        <div>
          <p>Executive Control</p>
          <h1>Kelola Pembayaran</h1>
        </div>
      </div>
    </div>

    <div class="page-content pay-content">

      <div class="pay-stats">
        <div class="pay-stat-card">
          <small>Total</small>
          <strong>${payments.length}</strong>
        </div>
        <div class="pay-stat-card warning">
          <small>Pending</small>
          <strong>${pendingCount}</strong>
        </div>
        <div class="pay-stat-card success">
          <small>Lunas</small>
          <strong>${paidCount}</strong>
        </div>
      </div>

      <div class="pay-section-title">PAYMENT REQUEST</div>

      <div class="pay-list">
        ${payments.map((payment) => $h`
          <div class="pay-card">
            <div class="pay-card-head">
              <div>
                <div class="pay-code">#${payment.id}</div>
                <h2>${payment.passenger}</h2>
              </div>

              <div class="pay-badge ${payment.status === 'Paid' ? 'paid' : 'pending'}">
                ${payment.status === 'Paid' ? 'LUNAS' : 'PENDING'}
              </div>
            </div>

            <div class="pay-route-box">
              <div>
                <span>RUTE</span>
                <strong>${payment.route}</strong>
              </div>
              <div>
                <span>METODE</span>
                <strong>${payment.method}</strong>
              </div>
            </div>

            <div class="pay-total-row">
              <div>
                <span>TOTAL PEMBAYARAN</span>
                <h3>Rp ${formatRupiah(payment.amount)}</h3>
              </div>
              <div class="pay-date">${payment.date}</div>
            </div>

            <div class="pay-action-row">
              <a @click="${() => verifyPayment(payment.id)}" class="pay-action approve">
                <i class="f7-icons">checkmark_alt</i>
                Verifikasi
              </a>

              <a @click="${() => rejectPayment(payment.id)}" class="pay-action reject">
                <i class="f7-icons">xmark</i>
                Tolak
              </a>

              <a @click="${() => viewTicket(payment.ticketId)}" class="pay-action detail">
                Tiket
              </a>
            </div>
          </div>
        `)}
      </div>

    </div>
  </div>
</template>

