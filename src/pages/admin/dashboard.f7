              </div>
              <div class="stat-info">
                <span class="stat-label">E-Tiket</span>
                <span class="stat-number">${tickets.length || 0}</span>
              </div>
            </div>
          </div>

          <div class="card card-outline dashboard-stat-card shadow-sm no-margin">
            <div class="card-content card-content-padding stat-card-inner">
              <div class="stat-icon-wrapper bg-yellow-tint">
                <i class="icon f7-icons color-yellow text-xl">bus_fill</i>
              </div>
              <div class="stat-info">
                <span class="stat-label">Armada</span>
                <span class="stat-number">${armadas.length || 0}</span>
              </div>
            </div>
          </div>

          <div class="card card-outline dashboard-stat-card shadow-sm no-margin">
            <div class="card-content card-content-padding stat-card-inner">
              <div class="stat-icon-wrapper bg-purple-tint">
                <i class="icon f7-icons color-purple text-xl">person_2_fill</i>
              </div>
              <div class="stat-info">
                <span class="stat-label">User</span>
                <span class="stat-number">${users.length || 0}</span>
              </div>
            </div>
          </div>

        </div>
      </div>

      <div class="block-title medium text-color-black font-extrabold" style="padding-left: 10px; margin-top: 30px; margin-bottom: 10px;">Manajemen Sistem</div>
      <div class="list inset list-strong list-outline custom-admin-list shadow-sm" style="margin-bottom: 30px;">
        <ul>
          <li>
            <a href="/admin/armadas/" class="item-link item-content py-2">
              <div class="item-media">
                <div class="menu-icon-wrapper bg-yellow-tint">
                  <i class="icon f7-icons text-lg color-yellow">bus_fill</i>
