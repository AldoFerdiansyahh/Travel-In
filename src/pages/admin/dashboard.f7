          <li>
            <a href="/admin/tickets/" class="item-link item-content py-2">
              <div class="item-media">
                <div class="menu-icon-wrapper bg-purple-tint">
                  <i class="icon f7-icons text-lg color-purple">doc_text_search</i>
                </div>
              </div>
              <div class="item-inner">
                <div class="item-title font-bold text-gray-800">Monitoring Tiket Penjualan</div>
              </div>
            </a>
          </li>

          <li>
            <a href="/admin/laporan/" class="item-link item-content py-2">
              <div class="item-media">
                <div class="menu-icon-wrapper bg-green-tint">
                  <i class="icon f7-icons text-lg color-green">graph_square_fill</i>
                </div>
              </div>
              <div class="item-inner">
                <div class="item-title font-bold text-gray-800">Fitur Laporan</div>
                <div class="after-title"><span class="badge color-green">Rp ${formatRupiah(calculateTotalRevenue())}</span></div>
              </div>
            </a>
          </li>
        </ul>
