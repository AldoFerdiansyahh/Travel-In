    </div>
  </div>
</template>

<style>
  /* Admin Navbar Styling */
  .custom-admin-nav {
    background: linear-gradient(135deg, #111827 0%, #1f2937 100%) !important;
  }

  /* Admin Header */
  .admin-welcome-header {
    background: linear-gradient(135deg, #111827 0%, #1f2937 100%);
    padding: 35px 5px 75px 5px;
    border-radius: 0 0 40px 40px;
  }

  /* Dashboard Colors */
  .bg-light-gray { background-color: #f9fafb; }

  /* Grid Gap Spacing */
  .grid-gap {
    --f7-grid-gap: 12px;
  }

  /* Stat Card Custom dengan Flexbox Horizontal */
  .dashboard-stat-card {
    border-radius: 20px !important;
    border: none !important;
    background: #ffffff !important;
    transition: all 0.3s ease;
  }

  .stat-card-inner {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: 16px 14px !important;
  }

  /* Ikon di bagian kiri */
  .stat-icon-wrapper {
    width: 44px;
    height: 44px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-right: 12px;
  }

  /* Ikon Tint Background */
  .bg-blue-tint { background-color: #eff6ff; }
  .bg-green-tint { background-color: #f0fdf4; }
  .bg-yellow-tint { background-color: #fefce8; }
  .bg-purple-tint { background-color: #faf5ff; }

  /* Info Teks di bagian kanan */
  .stat-info {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  
  .stat-label { 
    font-size: 11px; 
    color: #9ca3af; 
    font-weight: 700; 
    text-transform: uppercase; 
    letter-spacing: 0.05em; 
  }

  .stat-number { 
    font-size: 22px; 
    font-weight: 900; 
    color: #111827; 
    line-height: 1.1;
    margin-top: 2px;
  }

  /* Menu List Styling */
  .custom-admin-list { 
    border-radius: 20px !important; 
    overflow: hidden; 
    border: none !important;
    background: #ffffff !important;
  }

  .menu-icon-wrapper {
    width: 38px;
    height: 38px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>

<script>
  import $ from 'dom7';
  import { auth } from '../../js/firebase';
  import { signOut } from 'firebase/auth';

  export default (props, { $f7, $store, $router }) => {
    const currentUser = $store.getters.currentUser.value || {};
    const schedules = $store.getters.schedules.value || [];
    const tickets = $store.getters.tickets.value || [];
    const armadas = $store.getters.armadas.value || [];
    const users = $store.getters.users.value || [];

    // Hitung Total Pendapatan dari Tiket yang sukses / lunas
    const calculateTotalRevenue = () => {
      return tickets
        .filter(ticket => ticket.status === 'success' || ticket.status === 'completed' || ticket.status === 'PAID')
        .reduce((sum, ticket) => sum + (Number(ticket.totalPrice) || Number(ticket.price) || 0), 0);
    };

    // Format Mata Uang Rupiah sederhana
    const formatRupiah = (value) => {
      if (!value) return '0';
      return value.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ".");
    };

    // Fungsi Logout Admin
    const handleLogout = () => {
      $f7.dialog.confirm('Apakah Anda yakin ingin keluar dari Admin Panel?', 'Logout', async () => {
        $f7.preloader.show();
        try {
          await signOut(auth);
        } catch (err) {
          console.warn('Firebase signOut failed', err);
        }
        
        await $store.dispatch('logoutUser');
        $f7.preloader.hide();

        const appRouter = $router || ($f7.views && $f7.views.main && $f7.views.main.router);
        if (appRouter && appRouter.navigate) {
          appRouter.navigate('/login/', {
            reloadCurrent: true,
            ignoreCache: true,
          });
        } else {
          window.location.href = '/login/';
        }
      });
    };

    // Bind event klik manual
    $(document).off('click', '.admin-logout-btn').on('click', '.admin-logout-btn', (e) => {
      e.preventDefault();
      handleLogout();
    });

    return $render;
  };
</script>