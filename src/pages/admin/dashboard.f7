<template>
  <div class="page" data-name="admin-dashboard">
    <div class="navbar navbar-transparent">
      <div class="navbar-bg custom-admin-nav"></div>
      <div class="navbar-inner sliding">
        <div class="title text-color-white font-black tracking-wide">Admin Panel</div>
        <div class="right">
          <a href="#" class="link icon-only text-color-white admin-logout-btn" @click="${handleLogout}" style="width:44px; height:44px; display:flex; align-items:center; justify-content:center;">
            <i class="icon f7-icons text-xl">rectangle_portrait_and_arrow_right</i>
          </a>
        </div>
      </div>
    </div>

    <div class="page-content bg-light-gray">
      <div class="admin-welcome-header">
        <div class="block">
          <h1 class="no-margin text-color-white font-black">Halo, ${currentUser.name || 'Admin'}!</h1>
          <p class="no-margin text-color-white opacity-80 font-semibold mt-1">Kelola operasional & armada Travel-In di sini.</p>
        </div>
      </div>

      <div class="block" style="margin-top: -35px !important; position: relative; z-index: 10; padding: 0 8px;">
        <div class="grid grid-cols-2 grid-gap">
          
          <div class="card card-outline dashboard-stat-card shadow-sm no-margin">
            <div class="card-content card-content-padding stat-card-inner">
              <div class="stat-icon-wrapper bg-blue-tint">
                <i class="icon f7-icons color-blue text-xl">calendar_badge_plus</i>
              </div>
              <div class="stat-info">
                <span class="stat-label">Jadwal</span>
                <span class="stat-number">${schedules.length || 0}</span>
              </div>
            </div>
          </div>

          <div class="card card-outline dashboard-stat-card shadow-sm no-margin">
            <div class="card-content card-content-padding stat-card-inner">
              <div class="stat-icon-wrapper bg-green-tint">
